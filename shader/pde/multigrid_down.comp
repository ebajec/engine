#version 430 core
#extension GL_GOOGLE_include_directive : require

#include "multigrid.glsl"

// solving for H(phi) = f
// 				[lhs]   [rhs]
//
// R1 and R2 are intermediate grids for residuals and corrections.
// The "downwards" passes perform some jacobi iterations on the
// initial guess, then compute residuals for H(phi) = f and write
// these to R1.  Subsequenct passes downsample the grid in R1 for 
// the previous passes level and use it for f, write the smoothed
// residuals to R2 for use in later stages

// The level 0 iteration fetches directly from f. Subsequent iterations
// downsample the residuals from the previous pass

float RHS(ivec2 idx, uint level, out float wt)
{
	ivec2 size = imageSize(R1[level]);
	wt = test_boundary(idx,level);
	return bool(wt) ? imageLoad(R1[level], idx).r : 0;
}

float LHS(ivec2 idx, out float wt)
{
	ivec2 size = imageSize(in_lhs);
	wt = test_boundary(idx,0);
	return bool(wt) ? imageLoad(in_lhs, idx).r : 0;
}

float residual(ivec2 idx, float rhs, float h)
{
	float wt_c = boundary[idx.x][idx.y];
	float u = wt_c * block[idx.x][idx.y];

	if (wt_c < OOB_CELL_THRES) {
		return 0.f;
	}

	ivec2 l_idx = clamp(idx + ivec2(-1,0), ivec2(0), ivec2(GROUPS -1));
	ivec2 r_idx = clamp(idx + ivec2(1,0), ivec2(0), ivec2(GROUPS - 1));
	ivec2 t_idx = clamp(idx + ivec2(0,1), ivec2(0), ivec2(GROUPS - 1));
	ivec2 b_idx = clamp(idx + ivec2(0,-1), ivec2(0), ivec2(GROUPS - 1));

	float l = block[l_idx.x][l_idx.y];
	float r = block[r_idx.x][r_idx.y];
	float t = block[t_idx.x][t_idx.y];
	float b = block[b_idx.x][b_idx.y];

	float wt_l = boundary[l_idx.x][l_idx.y];
	float wt_r = boundary[r_idx.x][r_idx.y];
	float wt_t = boundary[t_idx.x][t_idx.y];
	float wt_b = boundary[b_idx.x][b_idx.y];

	float lap = (
		mix(u,l,wt_l) + mix(u,r,wt_r) + 
		mix(u,t,wt_t) + mix(u,b,wt_b) 
		- 4.f*u
	)/(h*h);

	return lap - rhs;
}

float fetch_lhs(ivec2 grid_idx, float rhs, float h)
{
	if (u_level > 0)
		return 0;
#if 0

	float wt;
	return LHS(grid_idx, wt);
#else
	// When fetching from the starting grid, perform one 
	// jacobi iteration on retrieval.
	ivec2 stencil[4] = {
		grid_idx + ivec2(-1, 0),
		grid_idx + ivec2(1, 0),
		grid_idx + ivec2(0, 1),
		grid_idx + ivec2(0, -1)
	};

	float wt_c = 0;
	float c = LHS(grid_idx, wt_c);

	c *= wt_c;

	if (!bool(wt_c))
		return 0.f;

	float sum = 0;
	float den = 0;

	for (int i = 0; i < 4; ++i) {
		float wt;
		float v = LHS(stencil[i], wt);

		wt = min(wt_c, wt);

		den += wt;
		sum += wt * v;
	}

	float u_next = den > 0 ? (sum - h*h*rhs)/den : 0;

	return mix(c, u_next, OMEGA); 
#endif
}

float fetch_rhs(ivec2 idx)
{
	// u_level == 0 is the original rhs; > 0
	// we downsample the residuals from the previous level
	if (u_level > 0) {
		ivec2 stencil[9] = {
			2*idx,

			2*idx + ivec2(-1,0),
			2*idx + ivec2(1,0),
			2*idx + ivec2(0,-1),
			2*idx + ivec2(0,1),

			2*idx + ivec2(-1,-1),
			2*idx + ivec2(-1,1),
			2*idx + ivec2(1,-1),
			2*idx + ivec2(1,1),
		};

		uint L = u_level - 1;

		float wt[9] = {1, 2,2,2,2, 1,1,1,1};

		float wt_c;
		float center = RHS(2*idx, L, wt_c);

		float num = 0;
		float den = 0;
		for (int i = 0; i < 9; ++i) {
			float wt_i;
			float value = RHS(stencil[i],L,wt_i);
			num += wt[i] * mix(center,value,wt_i);
			den += wt[i];
		}
		return den > 0 ? num/den : 0;
	}
	return imageLoad(in_rhs, idx).x;
}

void main()
{
	// index in local block
	ivec2 idx = ivec2(gl_LocalInvocationID.xy);

	// index in grid coordinates 
	// I.e., for groups = 8, j = 2
	// i i i i i i i i            
	// i i i i i i i i                             
	// i i o o o o i i                             
	// i i o o o o i i                             
	// i i o o o o i i                             
	// i i o o o o i i                             
	// i i i i i i i i                             
	// i i i i i i i i                             
	ivec2 out_idx = idx - ivec2(u_iterations); 

	int out_width = GROUPS - 2*int(u_iterations);

	ivec2 grid_idx = 
		ivec2(gl_WorkGroupID.xy) * out_width + out_idx;

	const float h = DELTA_X;

	float rhs = fetch_rhs(grid_idx);
	float lhs = fetch_lhs(grid_idx, rhs, h);
	float bd = test_boundary(grid_idx, u_level);

	if (bd < OOB_CELL_THRES) {
		rhs = 0;
		lhs = 0;
	}

	boundary[idx.x][idx.y] = bd; 
	block[idx.x][idx.y] = lhs;  

	for (int i = 0; i < u_iterations - 1; ++i) {
		barrier();

		lhs = jacobi_it(idx, rhs, h);

		barrier();

		block[idx.x][idx.y] = lhs;
	}
	barrier();

	bool outside = 
		out_idx.x < 0 || out_idx.y < 0 || 
		out_idx.x >= out_width || out_idx.y >= out_width; 

	if (outside)
		return;

	if (bd < OOB_CELL_THRES) { 
		lhs = 0;
		rhs = 0;
	}

	if (u_level < N) {
		float res = residual(idx, rhs, h);
		imageStore(R1[u_level], grid_idx, vec4(res,0,0,0));
	}

	if (u_level > 0) {
		imageStore(R2[u_level - 1], grid_idx, vec4(lhs,0,0,0));
	} else { 
		imageStore(tmp_lhs, grid_idx, vec4(lhs,0,0,0));
	}
}
